<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kids Fun Learning Quiz</title>

<style>
body {
    font-family: Comic Sans MS, cursive, sans-serif;
    background: linear-gradient(to right, #ffecd2, #fcb69f);
    text-align: center;
    margin: 0;
    padding: 0;
}

header {
    background: #ff6f61;
    padding: 15px;
    color: white;
    font-size: 28px;
}

.container {
    padding: 20px;
}

.question-box {
    background: white;
    padding: 20px;
    margin: 20px auto;
    width: 80%;
    border-radius: 15px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}

button {
    background: #4CAF50;
    color: white;
    padding: 10px 20px;
    margin: 10px;
    border: none;
    border-radius: 10px;
    font-size: 16px;
    cursor: pointer;
}

button:hover {
    background: #45a049;
}

img {
    width: 200px;
    border-radius: 10px;
    margin: 10px;
}

#result {
    font-size: 22px;
    font-weight: bold;
    color: #333;
}
video {
    margin-top: 20px;
    border-radius: 10px;
}
</style>
</head>

<body>

<header>🎉 Kids Fun Learning Quiz 🎉</header>

<!-- Background Music -->
<audio id="bgMusic" autoplay loop>
    <source src="https://www.bensound.com/bensound-music/bensound-happyrock.mp3" type="audio/mp3">
</audio>

<div class="container">

    <h2>🐶 Question 1: Which animal says "Woof"?</h2>
    <img src="https://images.unsplash.com/photo-1517849845537-4d257902454a" alt="Dog">
    <div class="question-box">
        <button onclick="checkAnswer(1)">Cat</button>
        <button onclick="checkAnswer(2)">Dog</button>
        <button onclick="checkAnswer(1)">Cow</button>
    </div>

    <h2>🍎 Question 2: Which one is a fruit?</h2>
    <img src="https://images.unsplash.com/photo-1567306226416-28f0efdc88ce" alt="Apple">
    <div class="question-box">
        <button onclick="checkAnswer(2)">Carrot</button>
        <button onclick="checkAnswer(2)">Apple</button>
        <button onclick="checkAnswer(2)">Potato</button>
    </div>

    <div id="result"></div>

    <!-- Educational Video -->
    <h2>🎬 Watch & Learn!</h2>
    <video width="320" height="240" controls>
        <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">
    </video>

</div>

<script>
let score = 0;
let answered = 0;

function checkAnswer(correctOption) {
    if (correctOption === 2) {
        score++;
        alert("🎉 Correct Answer!");
    } else {
        alert("❌ Try Again!");
    }
    answered++;
    if (answered === 2) {
        document.getElementById("result").innerHTML = 
        "⭐ Your Final Score: " + score + " / 2";
    }
}
</script>

</body>
</html>
